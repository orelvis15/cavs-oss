# Staged native libraries are build artifacts, produced by each SDK's build
# step (`make native`, prebuild scripts) or by the release workflow. The C
# header is checked in; the compiled libraries are not.
**/native/*.so
**/native/*.dylib
**/native/*.dll
**/native/*.a
go/cavs/native/*.so
go/cavs/native/*.dylib
go/cavs/native/*.dll

# Node
node/node_modules/
node/dist/
node/*.node
node/prebuilds/
# Per-platform packages staged by the release workflow (contain the compiled
# native libraries); regenerated by build-npm-platform-packages.mjs.
node/npm/

# Kotlin / JVM
kotlin/.gradle/
kotlin/build/
kotlin/**/build/
kotlin/.kotlin/

# Compiled example/demo binaries (from `go build`/`cargo build` of the
# examples). Sources live in each SDK's examples/ dir; binaries do not.
**/examples/**/*.exe
go/examples/quickstart/quickstart
go/examples/preview/preview
